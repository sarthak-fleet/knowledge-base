{
  "name": "knowledgebase-app",
  "version": "0.1.0",
  "private": true,
  "description": "Knowledgebase dashboard — Next.js app talking to the RAG Worker API. Deployed to Cloudflare Workers via OpenNext.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "cf:build": "next build --webpack && opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare populateCache local",
    "preview:cf": "pnpm cf:build && opennextjs-cloudflare preview",
    "deploy:cf": "pnpm cf:build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.11.0",
    "next": "16.2.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "swr": "2.4.1",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "lightningcss": "^1.32.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
