{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "knowledgebase-bench",
  "main": "src/service-bench.ts",
  "compatibility_date": "2026-06-20",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "services": [
    {
      "binding": "RAG_SERVICE",
      "service": "knowledgebase"
    }
  ]
}
