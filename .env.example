# --- LLM (OpenAI-compatible, DeepSeek default; matches HighSignal convention) ---
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-replace-me
AI_MODEL=deepseek-v4-flash
# Optional override for the extraction (cheaper) vs synthesis (smarter) stages
KB_EXTRACT_MODEL=
KB_SYNTHESIZE_MODEL=
# Optional: routing gateways (e.g. free-AI gateway) require a project_id in
# the request body for tenancy/billing. Leave blank for vanilla OpenAI / DeepSeek.
# Example free-gateway config:
#   AI_BASE_URL=https://free-ai-gateway.example.workers.dev/v1
#   AI_API_KEY=<gateway-token>
#   AI_MODEL=gemini-2.5-flash    # see GET /v1/models for the full list
#   AI_PROJECT_ID=kb-service
AI_PROJECT_ID=

# --- Embeddings (local by default via fastembed; no API key needed) ---
# Default: bge-small (384d). Upgrade options:
#   - BAAI/bge-base-en-v1.5 (768d)  — modest quality bump, 2× embedding size
#   - intfloat/e5-large-v2 (1024d)  — much better but slower on CPU
# Changing embed model requires re-ingest + Qdrant collection re-create.
KB_EMBED_MODEL=BAAI/bge-large-en-v1.5
KB_SPARSE_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions
KB_EMBED_DIM=1024

# Judge / RAGAS / verify model — defaults to AI_MODEL if unset. Use a cheaper
# model here to save tokens on the eval loop.
KB_JUDGE_MODEL=

# Deterministic LLM response cache (eval replay). When set, every
# (model, system, user, params) tuple is hashed to a file under this dir.
# Subsequent identical calls return the cached response — no LLM call, no
# cost, perfect reproducibility. Off by default. Inside Docker prefer
# /data/llm_cache so the cache survives container rebuilds.
KB_LLM_CACHE_DIR=

# --- Storage ---
KB_POSTGRES_DSN=postgresql+asyncpg://kb:kb@postgres:5432/kb
KB_QDRANT_URL=http://qdrant:6333
KB_QDRANT_API_KEY=
KB_VECTOR_STORE=qdrant   # qdrant | pgvector
KB_OBJECT_STORE=minio    # minio | local
KB_MINIO_ENDPOINT=minio:9000
KB_MINIO_ACCESS_KEY=kbminio
KB_MINIO_SECRET_KEY=kbminio-secret
KB_MINIO_BUCKET=kb-bucket
KB_LOCAL_DATA_DIR=/data

# --- API ---
KB_API_HOST=0.0.0.0
KB_API_PORT=8000
KB_LOG_LEVEL=info

# --- Workers ---
# Number of asyncio tasks claiming ingest jobs concurrently. Each task can
# hold one parsed document in memory; `hi_res` parsing on a 300-page 10-K
# uses ~2 GB. Safe defaults by host RAM:
#   8 GB → 1, 16 GB → 2, 32 GB → 4.
# Bump only if your corpus is light or `parse_strategy_default` is `fast`.
KB_WORKER_CONCURRENCY=2
KB_PARSE_STRATEGY_DEFAULT=auto   # auto | fast | hi_res | ocr_only

# --- EDGAR (only used by `make seed`, not the runtime) ---
SEC_USER_AGENT=Sarthak Agrawal sarthakagrawal927@gmail.com
