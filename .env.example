# --- LLM (OpenAI-compatible, DeepSeek default; matches HighSignal convention) ---
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-replace-me
AI_MODEL=deepseek-v4-flash
# Optional override for the extraction (cheaper) vs synthesis (smarter) stages
KB_EXTRACT_MODEL=
KB_SYNTHESIZE_MODEL=

# --- Embeddings (local by default via fastembed; no API key needed) ---
# Default: bge-small (384d). Upgrade options:
#   - BAAI/bge-base-en-v1.5 (768d)  — modest quality bump, 2× embedding size
#   - intfloat/e5-large-v2 (1024d)  — much better but slower on CPU
# Changing embed model requires re-ingest + Qdrant collection re-create.
KB_EMBED_MODEL=BAAI/bge-small-en-v1.5
KB_SPARSE_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions
KB_EMBED_DIM=384

# Judge / RAGAS / verify model — defaults to AI_MODEL if unset. Use a cheaper
# model here to save tokens on the eval loop.
KB_JUDGE_MODEL=

# --- Storage ---
KB_POSTGRES_DSN=postgresql+asyncpg://kb:kb@postgres:5432/kb
KB_QDRANT_URL=http://qdrant:6333
KB_QDRANT_API_KEY=
KB_VECTOR_STORE=qdrant   # qdrant | pgvector
KB_OBJECT_STORE=minio    # minio | local
KB_MINIO_ENDPOINT=minio:9000
KB_MINIO_ACCESS_KEY=kbminio
KB_MINIO_SECRET_KEY=kbminio-secret
KB_MINIO_BUCKET=kb-bucket
KB_LOCAL_DATA_DIR=/data

# --- API ---
KB_API_HOST=0.0.0.0
KB_API_PORT=8000
KB_LOG_LEVEL=info

# --- Workers ---
KB_WORKER_CONCURRENCY=4
KB_PARSE_STRATEGY_DEFAULT=auto   # auto | fast | hi_res | ocr_only

# --- EDGAR (only used by `make seed`, not the runtime) ---
SEC_USER_AGENT=Sarthak Agrawal sarthakagrawal927@gmail.com
